# =============================================================================
#  RenDoc – Environment Variables
#  Copy this file to .env and fill in real values.
#  Never commit the real .env — it is already in .gitignore.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_DB=rendoc
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_in_production

# --- Spring Boot ---
# Must be ≥ 32 characters
JWT_SECRET=change_me_to_a_very_long_secure_random_string_here
JWT_EXPIRATION_MS=86400000

# local dev: "dev" | docker prod: "prod"
SPRING_PROFILE=prod

# --- CORS ---
# In Docker the nginx reverse-proxy handles /api, so localhost is fine
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Vite (build-time) ---
# When served via nginx proxy, /api/v1 is relative → no hard-coded host needed
VITE_API_BASE_URL_V1=/api/v1
